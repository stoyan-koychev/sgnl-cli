{
  "name": "sgnl-cli",
  "version": "1.1.0",
  "description": "SGNL — Signal Intelligence CLI: analyze any URL for performance, SEO, and structure",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sgnl": "dist/cli.js"
  },
  "files": [
    "dist/",
    "python/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "setup-python": "bash scripts/setup-python.sh",
    "postinstall": "node scripts/ensure-python-deps.js",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "keywords": [
    "seo",
    "performance",
    "cli",
    "analysis",
    "web-vitals",
    "pagespeed",
    "sgnl",
    "signal"
  ],
  "author": "STOYAN",
  "license": "MIT",
  "homepage": "https://github.com/stoyan-koychev/sgnl-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stoyan-koychev/sgnl-cli.git"
  },
  "bugs": {
    "url": "https://github.com/stoyan-koychev/sgnl-cli/issues"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "eslint": "^9.39.4",
    "ink-testing-library": "^2.1.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "axios": "1.13.6",
    "commander": "^14.0.3",
    "google-auth-library": "^10.6.2",
    "ink": "^3.2.0",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.8.0"
}
